            plt.title("Processed")
            plt.imshow(processed, cmap="gray")
            plt.axis("off")
            plt.show()

        return {"card_number": parse_card_number(text)}

    elif "OldGen" in image_path:
        crop = crop_old_gen(image)
        processed = preprocess_for_ocr(crop)
        text = reader.readtext(crop, detail=0)

        if show_crops:
            plt.figure(figsize=(10, 4))
            plt.subplot(1, 2, 1)
            plt.title("Crop")
            plt.imshow(cv2.cvtColor(crop, cv2.COLOR_BGR2RGB))
            plt.axis("off")

            plt.subplot(1, 2, 2)
            plt.title("Processed")
            plt.imshow(processed, cmap="gray")
            plt.axis("off")
            plt.show()

        return {"card_number": parse_card_number(text)}

    elif "EReader" in image_path:
        crop = crop_e_reader(image)
        processed = preprocess_for_ocr(crop)
        text = reader.readtext(crop, detail=0)

        if show_crops:
            plt.figure(figsize=(10, 4))
            plt.subplot(1, 2, 1)
            plt.title("Crop")
            plt.imshow(cv2.cvtColor(crop, cv2.COLOR_BGR2RGB))
            plt.axis("off")

            plt.subplot(1, 2, 2)
            plt.title("Processed")
            plt.imshow(processed, cmap="gray")
            plt.axis("off")
            plt.show()

        return {"card_number": parse_card_number(text)}

    else:
        print("Not currently supported")
        return None

