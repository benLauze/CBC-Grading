import cv2
import easyocr
import numpy as np
import re
import matplotlib.pyplot as plt


# This OCR Pipeline will be used to challenge and confirm the outputs provided by an AI/ML model that detects Pokemon Cards and identifies them
# This is not the final product

# Initialize
reader = easyocr.Reader(['en'], gpu=False)

# Crop
def crop_bottom_regions(image, height_ratio=0.11, width_ratio=0.4):
    h, w, _ = image.shape

    # Bottom strip height
    y1 = int(h * (1 - height_ratio))
    y2 = h

    # Left half
    x1_left = 0
    x2_left = int(w * width_ratio)

    # Right half
    x1_right = int(w * (1 - width_ratio))
    x2_right = w

    bottom_left = image[y1:y2, x1_left:x2_left]
    bottom_right = image[y1:y2, x1_right:x2_right]

    return bottom_left, bottom_right

# Gray Scale
def preprocess_for_ocr(crop):
    gray = cv2.cvtColor(crop, cv2.COLOR_BGR2GRAY)
    gray = cv2.bilateralFilter(gray, 11, 17, 17)
    gray = cv2.equalizeHist(gray)
    return gray

# Card Number
def parse_card_number(text_list):
    for text in text_list:
        # Handle variations like "001/165", "001 /165", "001/ , XY01, 001"
        match = re.search(r"(\d{1,3}\s*/\s*\d{1,3})|([A-Za-z]\d{1,3})|(\d{1,3})"
, text)
        if match:
            return match.group().replace(" ", "")
    return None

# Set code
def parse_set_code(text_list):
    for text in text_list:
        match = re.search(r"[a-z]+e[a-z]\b", text, re.IGNORECASE)
        if match:
            return match.group()[:-2]
    return None

# Extract
def extract_card_info(image_path, show_crops=True):
    # Load image
    image = cv2.imread(image_path)
    if image is None:
        raise ValueError("Could not load image")

    # Crop bottom-left and bottom-right
    bottom_left, bottom_right = crop_bottom_regions(image)

    # Preprocess both
    left_processed = preprocess_for_ocr(bottom_left)
    right_processed = preprocess_for_ocr(bottom_right)

    # OCR both sides
    left_text = reader.readtext(left_processed, detail=0)
    right_text = reader.readtext(right_processed, detail=0)

    # Combine OCR results
    all_text = left_text + right_text

    # Show crops (optional)
    if show_crops:
        plt.figure(figsize=(12, 6))

        plt.subplot(2, 2, 1)
        plt.title("Bottom Left Crop")
        plt.imshow(cv2.cvtColor(bottom_left, cv2.COLOR_BGR2RGB))
        plt.axis("off")

        plt.subplot(2, 2, 2)
        plt.title("Bottom Right Crop")
        plt.imshow(cv2.cvtColor(bottom_right, cv2.COLOR_BGR2RGB))
        plt.axis("off")

        plt.subplot(2, 2, 3)
        plt.title("Left Preprocessed")
        plt.imshow(left_processed, cmap="gray")
        plt.axis("off")

        plt.subplot(2, 2, 4)
        plt.title("Right Preprocessed")
        plt.imshow(right_processed, cmap="gray")
        plt.axis("off")

        plt.show()

    # Parse results
    card_number = parse_card_number(all_text)
    set_code = parse_set_code(all_text)

    return {
        "card_number": card_number,
        #"set_code": set_code
    }

